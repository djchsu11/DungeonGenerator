<section class="dungeongen-form">
  <div class="form-group">
    <label>{{localize "DUNGEONGEN.form.name"}}</label>
    <input type="text" name="name" placeholder="(auto-generated if blank)" />
  </div>

  <div class="form-group">
    <label>{{localize "DUNGEONGEN.form.partyLevel"}}</label>
    <input type="number" name="partyLevel" min="1" max="20" value="1" required />
  </div>

  <div class="form-group">
    <label>{{localize "DUNGEONGEN.form.family"}}</label>
    <select name="familyId">
      <option value="">— any / no family —</option>
      {{#each families}}
        <option value="{{id}}">{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize "DUNGEONGEN.form.familyTraits"}}</label>
    <input type="text" name="familyTraits" placeholder="e.g. goblin, dog (comma-separated)" />
    <p class="hint">{{localize "DUNGEONGEN.form.familyTraitsHint"}}</p>
  </div>

  <div class="form-group">
    <label>{{localize "DUNGEONGEN.form.archetype"}}</label>
    <select name="archetype">
      <option value="">— auto (from family) —</option>
      {{#each archetypes}}
        <option value="{{id}}">{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize "DUNGEONGEN.form.size"}}</label>
    <select name="size">
      {{#each sizes}}
        <option value="{{id}}" {{#if (eq id "medium")}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize "DUNGEONGEN.form.lighting"}}</label>
    <select name="lighting">
      {{#each lightings}}
        <option value="{{id}}" {{#if (eq id "torchlit")}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize "DUNGEONGEN.form.lootGenerosity"}}</label>
    <select name="lootGenerosity">
      {{#each generosity}}
        <option value="{{id}}" {{#if (eq id "standard")}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize "DUNGEONGEN.form.puzzleDensity"}}</label>
    <select name="puzzleDensity">
      {{#each puzzleDensity}}
        <option value="{{id}}" {{#if (eq id "normal")}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize "DUNGEONGEN.form.climax"}}</label>
    <select name="climaxThreat">
      {{#each climax}}
        <option value="{{id}}" {{#if (eq id "severe")}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  <footer class="form-footer">
    <button type="submit"><i class="fa-solid fa-dungeon"></i> {{localize "DUNGEONGEN.form.generate"}}</button>
  </footer>
</section>
